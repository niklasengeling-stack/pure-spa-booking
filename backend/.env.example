# TAC-Adapter: "mock" (Standard, ohne TAC-Zugang) oder "real" (nach TAC-Freigabe)
TAC_MODE=mock
PORT=3001

# Nur für TAC_MODE=real – aus der TAC-Interface-Spezifikation eintragen:
# TAC_BASE_URL=https://<tac-interface-host>/...
# TAC_API_KEY=<von TAC bereitgestellter Schlüssel>

# Payment-Adapter: "onsite" (Standard, Pilot: Zahlung vor Ort) oder "tacpay" (nach TAC|Pay-Freigabe)
PAYMENT_MODE=onsite

# Nur für PAYMENT_MODE=tacpay – aus der TAC|Pay-Spezifikation eintragen:
# TACPAY_BASE_URL=https://<tacpay-host>/...
# TACPAY_API_KEY=<von TAC|Pay bereitgestellter Schlüssel>
# TACPAY_WEBHOOK_SECRET=<Webhook-Signatur-Geheimnis>
